{ "manifest_version": 3, "name": "YouTube Status and Feature Restorer", "version": "1.0.0", "description": "Restore and access YouTube features from 2017-2020", "permissions": ["storage", "activeTab", "scripting"], "host_permissions": ["https://www.youtube.com/*", "https://youtube.com/*"], "background": { "service_worker": "background.js" }, "action": { "default_title": "YouTube Status and Feature Restorer", "default_icon": "icon.png", "default_popup": "popup.html" }, "icons": { "128": "icon.png" } }