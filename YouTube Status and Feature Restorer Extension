{ "manifest_version": 3, "name": "YouTube Status and Feature Restorer", "version": 
"1.0.0", "description": "Restore and access YouTube features from 2017-2020",
"permissions": ["storage", "activeTab", "scripting"], "host_permissions":
["https://www.youtube.com/*", "https://youtube.com/*"], "background": { "service_worker": "background.js" },
"action": { "default_title": "YouTube Status and Feature Restorer", "default_icon": "icon.png", "default_popup": "popup.html" }, "icons": { "128": "icon.png" } }
// YouTube Status and Feature Restorer - Background Script

// Initialize extension on install
chrome.runtime.onInstalled.addListener(() => {
  console.log('YouTube Status and Feature Restorer installed successfully');
  chrome.storage.local.set({
    features: {
      classicUploadInterface: true,
      oldCommentsSystem: true,
      layout2017: true,
      features2018_2020: true
    }
  });
});

// Listen for tab updates
chrome.tabs.onUpdated.addListener((tabId, changeInfo, tab) => {
  if (changeInfo.status === 'complete' && tab.url.includes('youtube.com')) {
    console.log('YouTube tab detected:', tab.url);
    restoreFeatures(tabId);
  }
});

// Function to restore YouTube features
function restoreFeatures(tabId) {
  chrome.storage.local.get(['features'], (result) => {
    if (result.features) {
      chrome.tabs.sendMessage(tabId, {
        action: 'applyFeatures',
        features: result.features
      }).catch((error) => {
        console.log('Content script not yet loaded:', error);
      });
    }
  });
}

// Message listener for communication with content scripts
chrome.runtime.onMessage.addListener((request, sender, sendResponse) => {
  if (request.action === 'getFeatures') {
    chrome.storage.local.get(['features'], (result) => {
      sendResponse(result.features);
    });
    return true; // Keep the message channel open
  }
});

// Available features from 2017-2020
const availableFeatures = {
  classicUploadInterface: 'Classic Upload Interface (2017-2019)',
  oldCommentsSystem: 'Old Comments System (2017-2018)',
  layout2017: '2017 YouTube Layout',
  features2018_2020: '2018-2020 Features Pack',
  classicSearch: 'Classic Search Bar (2017)',
  oldSubscriptionsPage: 'Old Subscriptions Page (2018)',
  legacyPlaylist: 'Legacy Playlist Layout (2017-2019)',
  classicChannelDesign: 'Classic Channel Design (2018-2019)'
};

console.log('YouTube Status and Feature Restorer Background Service Worker Active');
console.log('Available Features:', availableFeatures);


